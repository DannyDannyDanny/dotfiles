{
  "uid": "crowdsec",
  "title": "🛡️ CrowdSec",
  "tags": ["fleet", "security"],
  "editable": true,
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "graphTooltip": 1,
  "style": "dark",
  "links": [],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Bans",
      "description": "Current number of active ban decisions in the LAPI.",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short",
          "noValue": "0"
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(cs_active_decisions{action=\"ban\"}) or vector(0)",
        "legendFormat": "bans",
        "refId": "A"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Captchas",
      "description": "Current number of active captcha decisions.",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 }
            ]
          },
          "unit": "short",
          "noValue": "0"
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(cs_active_decisions{action=\"captcha\"}) or vector(0)",
        "legendFormat": "captchas",
        "refId": "A"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Alert Rate (1h)",
      "description": "Buckets that overflowed (scenario triggered) in the last hour.",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "short",
          "noValue": "0"
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(increase(cs_bucket_overflow_total[1h])) or vector(0)",
        "legendFormat": "alerts",
        "refId": "A"
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Events Parsed (1h)",
      "description": "Log events processed by the CrowdSec parser in the last hour.",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "unit": "short",
          "noValue": "0"
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(increase(cs_parser_hits_total[1h]))",
        "legendFormat": "events",
        "refId": "A"
      }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Alert Rate by Scenario",
      "description": "CrowdSec bucket overflows (scenario triggers) per second.",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "rate(cs_bucket_overflow_total[5m])",
        "legendFormat": "{{name}}",
        "refId": "A"
      }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Active Bans Over Time",
      "description": "Total active ban decisions in the LAPI.",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "cs_active_decisions{action=\"ban\"}",
        "legendFormat": "{{reason}}",
        "refId": "A"
      }]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Active Decisions",
      "description": "Current bans broken down by scenario, origin, and type.",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "sortBy": [{ "displayName": "Value", "desc": true }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [{
          "matcher": { "id": "byName", "options": "Value" },
          "properties": [{ "id": "custom.width", "value": 80 }]
        }]
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "cs_active_decisions",
        "legendFormat": "{{reason}}",
        "refId": "A",
        "instant": true,
        "format": "table"
      }],
      "transformations": [
        { "id": "organize", "options": {
          "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
          "renameByName": { "action": "Action", "origin": "Origin", "reason": "Scenario", "type": "Type", "Value": "Count" }
        }}
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Events Ingested by Source",
      "description": "Log events hitting the parser per source (Caddy files, SSH journalctl).",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "rate(cs_parser_hits_total[5m])",
        "legendFormat": "{{source}}",
        "refId": "A"
      }]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Parser Hit Rate",
      "description": "Events hitting the parser (total vs ok). High miss rate indicates unrecognised log formats.",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1, "fillOpacity": 5 },
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(cs_parser_hits_total[5m])",
          "legendFormat": "{{source}} total",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(cs_parser_hits_ok_total[5m])",
          "legendFormat": "{{source}} ok",
          "refId": "B"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "LAPI Request Rate",
      "description": "HTTP requests to the local CrowdSec LAPI (from bouncers + cscli).",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1, "fillOpacity": 5 },
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "rate(cs_lapi_route_requests_total[5m])",
        "legendFormat": "{{method}} {{route}} ({{code}})",
        "refId": "A"
      }]
    }
  ]
}
