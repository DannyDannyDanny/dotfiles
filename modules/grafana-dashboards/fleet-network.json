{
  "uid": "fleet-network",
  "title": "🌊 Currents (Network)",
  "tags": [
    "fleet",
    "homelab"
  ],
  "editable": true,
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
