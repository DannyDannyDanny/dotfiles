{
  "uid": "fleet-command-bridge",
  "title": "⚓ Fleet Command Bridge",
  "tags": [
    "fleet",
    "homelab"
  ],
  "editable": true,
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "weekStart": "",
  "style": "dark",
  "links": [],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "ship",
        "label": "Ship",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(up{job=\"node\"}, alias)",
          "refId": "StandardVariableQuery"
        },
        "definition": "label_values(up{job=\"node\"}, alias)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "options": [],
        "regex": "",
        "sort": 1,
        "hide": 0,
        "skipUrlSync": false
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "type": "dashboard",
        "name": "Annotations & Alerts",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "🚢 Fleet Muster — who's afloat",
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "up{job=\"node\",alias=~\"$ship\"}",
          "refId": "A",
          "legendFormat": "{{alias}}",
          "editorMode": "code",
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 1,
                "color": "green"
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "⚓ ADRIFT",
                  "color": "red",
                  "index": 1
                },
                "1": {
                  "text": "⛵ AFLOAT",
                  "color": "green",
                  "index": 0
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value_and_name"
      },
      "pluginVersion": "11.0.0"
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "⚙️ CPU load",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 * (1 - avg by (alias) (rate(node_cpu_seconds_total{mode=\"idle\",alias=~\"$ship\"}[5m])))",
          "refId": "A",
          "legendFormat": "{{alias}}",
          "editorMode": "code",
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 70,
                "color": "yellow"
              },
              {
                "value": 85,
                "color": "red"
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "pluginVersion": "11.0.0"
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "🧠 Memory used",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 * (1 - node_memory_MemAvailable_bytes{alias=~\"$ship\"} / node_memory_MemTotal_bytes{alias=~\"$ship\"})",
          "refId": "A",
          "legendFormat": "{{alias}}",
          "editorMode": "code",
          "instant": true,
          "range": false
